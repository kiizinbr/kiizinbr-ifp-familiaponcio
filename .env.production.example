# ============================================================
# IFP Connect — Variáveis de PRODUÇÃO
# Copie para .env.production no servidor e NUNCA commite.
# Use: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# ============================================================

# Postgres (interno ao docker network)
POSTGRES_USER=ifp
POSTGRES_PASSWORD=__GERAR_COM__openssl_rand_-base64_32__
POSTGRES_DB=ifp_connect

# Redis (interno ao docker network)
REDIS_PASSWORD=__GERAR_COM__openssl_rand_-base64_32__

# Domínios públicos (preencher com o domínio comprado e DNS apontando pro VPS)
WEB_DOMAIN=ifp.exemplo.org.br
API_DOMAIN=api.ifp.exemplo.org.br
WEB_ORIGIN=https://ifp.exemplo.org.br

# Auth — gerar com: openssl rand -base64 32
JWT_SECRET=__TROCAR__
JWT_EXPIRES_IN=8h
NEXTAUTH_SECRET=__TROCAR__

# Caddy (Let's Encrypt)
ACME_EMAIL=ti@exemplo.org.br

# ============================================================
# Super Admin inicial (PRODUÇÃO) — só para o seed MÍNIMO.
# ============================================================
# PROD usa o seed mínimo `seed:admin` (cria SÓ o Super Admin + as unidades),
# NUNCA o seed DEV completo (`pnpm --filter @ifp/database seed`), que injeta
# famílias/CPFs fictícios, prontuários e fixtures de teste na base.
#
# Rode UMA VEZ após o `migrate`, com o gate explícito SEED_ADMIN_ONLY=true:
#   docker compose -f docker-compose.prod.yml -f docker-compose.tailscale.yml \
#     --env-file .env.production --profile tools run --rm \
#     -e SEED_ADMIN_ONLY=true \
#     migrate pnpm --filter @ifp/database seed:admin
#
# As duas vars abaixo são lidas pelo seed:admin (não pelo migrate). Defina-as
# só na hora de rodar o seed (ou aqui) e troque a senha no 1º login.
SEED_SUPER_ADMIN_EMAIL=admin@ifp.org.br
SEED_SUPER_ADMIN_PASSWORD=__TROCAR_E_REDEFINIR_NO_1o_LOGIN__
