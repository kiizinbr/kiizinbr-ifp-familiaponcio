generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  mustChangePassword Boolean @default(false)
  name           String?
  image          String?
  accounts       Account[]
  sessions       Session[]

  // RBAC (Plano 2)
  userRoles        UserRole[]
  primaryRoleName  String?    // 'super_admin' | 'presidencia' | 'gestor_unidade' | ...
  primaryUnitScope String?    // 'medico' | 'capacitacao' | 'esportivo' | 'recreativo' | null
  auditLogs        AuditLog[]
  passwordResetTokens PasswordResetToken[]

  // Cidadao (Plano 3) — reverse relations
  cidadaosCriados Cidadao[]      @relation("CidadaoCreatedBy")
  anexosEnviados  AnexoCidadao[] @relation("AnexoUploadedBy")

  // Triagem (Plano 4) — reverse relations
  triagensConduzidas      Triagem[]              @relation("TriagemAssistente")
  elegibilidadesDecididas ElegibilidadeUnidade[] @relation("ElegibilidadeDecidida")

  // Funil (Fatia A) — reverse relations
  vagasCriadas        Vaga[]        @relation("VagaCriadaPor")
  agendamentosCriados Agendamento[] @relation("AgendamentoCriadoPor")

  // Médico (F1.B.1) — reverse relation
  profissional Profissional?

  // Capacitação (F1.A.1) — reverse relations
  cursosCriados Curso[]    @relation("CursoCriadoPor")
  instrutor     Instrutor?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Token de redefinição de senha (admin-driven, Fase 1). Guarda só o HASH (sha256)
/// do token — o raw só existe no link entregue ao usuário. Expira; uso único (usedAt).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// RBAC tables (Plano 2)

/// Os 6 roles vigentes (gestor_geral removido em 2026-05-28 — T3/T4 RBAC v2).
/// Nome é a chave estável: super_admin, presidencia, gestor_unidade,
/// social, profissional, recepcao.
model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  /// 'global' = role sem unit_scope (super_admin, presidencia, social)
  /// 'unit' = role exige unit_scope (gestor_unidade, profissional, recepcao)
  scope       String     @default("global")
  userRoles   UserRole[]
  createdAt   DateTime   @default(now())
}

/// Associação many-to-many User↔Role com unit_scope opcional.
/// Ex: Raquel tem 1 entry — (gestor_unidade, 'medico').
/// Regina tem 1 entry — (social, null).
/// Maria callcenter tem 1 entry — (recepcao, 'medico').
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  unitScope String?  // null se role.scope = 'global'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId, unitScope])
  @@index([userId])
  @@index([roleId])
}

/// Audit log append-only. Detalhes de scope/retenção: Plano 2 §0.3 e §0.4 (ainda abertas).
model AuditLog {
  id         String   @id @default(cuid())
  /// null para eventos pre-auth (signin_attempt sem user known)
  userId     String?
  /// signin_success, signin_failed, ficha_created, role_changed, etc.
  action     String
  entityType String?  // 'cidadao', 'anexo_cidadao', 'user', 'role', etc.
  entityId   String?
  /// Entidade-raiz do evento (aggregate root). Correlaciona sub-entidades:
  /// um anexo (entityType='anexo_cidadao') aponta seu cidadão aqui, permitindo
  /// "histórico do cidadão X" como query indexada. Plano 4 (triagem) reusa.
  rootEntityType String?
  rootEntityId   String?
  meta       Json?
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([rootEntityType, rootEntityId, createdAt])
  @@index([createdAt])
}

// Plano 3 — Ficha Cidadã (decisões §0.1 a §0.10 fechadas em 2026-05-24)

/// Família que agrupa um ou mais cidadãos atendidos.
/// Ex: "Família Almeida" com membros mãe (Cidadao), pai (Cidadao) e dois filhos (Familiar).
model Familia {
  id             String     @id @default(cuid())
  nomeReferencia String     // ex: "Família Almeida"
  observacoes    String?    @db.Text
  cidadaos       Cidadao[]
  familiares     Familiar[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

/// Membro de família que NÃO tem Ficha Cidadã própria (criança pequena, idoso sem CPF).
/// Quando esse membro evoluir pra Cidadão (ex: adquirir CPF), cria-se Cidadao e linka via familiaId.
model Familiar {
  id             String    @id @default(cuid())
  familiaId      String
  familia        Familia   @relation(fields: [familiaId], references: [id], onDelete: Cascade)
  nome           String
  parentesco     String    // ex: "filho", "esposa", "mãe", "neto"
  dataNascimento DateTime? @db.Date
  idadeAprox     Int?      // se data desconhecida
  observacoes    String?
  createdAt      DateTime  @default(now())

  @@index([familiaId])
}

/// Ficha Cidadã — registro central de cada pessoa atendida pelo IFP.
/// Schema definido em §0.1 (34 campos: 4 obrigatórios + 23 opcionais + 7 sistema).
model Cidadao {
  id String @id @default(cuid())

  // Obrigatórios (§0.1)
  nomeCompleto      String
  cpf               String   @unique // 11 dígitos normalizado (sem ponto/traço)
  dataNascimento    DateTime @db.Date
  telefonePrincipal String

  // Identificação opcional
  nomeSocial           String?
  rg                   String?
  documentoAlternativo String? // CNH, passaporte
  genero               String? // 'feminino' | 'masculino' | 'nao_binario' | 'nao_informar'
  corRaca              String? // IBGE: 'branca' | 'preta' | 'parda' | 'amarela' | 'indigena'
  estadoCivil          String?
  nacionalidade        String?
  naturalidade         String? // cidade + UF
  nomeMae              String?
  nomePai              String?
  escolaAtual          String? // pra criança/adolescente

  // Contato opcional
  telefoneSecundario String?
  email              String?
  whatsappConsente   Boolean @default(false) // LGPD base legal pra contato WhatsApp

  // Socioeconômico (visível só pra perfil `social` via RBAC) — §0.5
  rendaFamiliar     Decimal? @db.Decimal(10, 2)
  pessoasNaCasa     Int?
  beneficioSocial   String? // 'bolsa_familia' | 'bpc' | 'nenhum' | 'outro'
  escolaridade      String?
  trabalha          Boolean?
  trabalhoDescricao String?

  // Saúde (visível só pra `profissional` do Centro Médico via RBAC)
  tipoSanguineo     String?
  alergias          String? @db.Text
  medicamentosEmUso String? @db.Text
  condicoesCronicas String? @db.Text

  // Sistema — foto separada de anexos (§0.5)
  fotoUrl       String?
  createdById   String
  createdBy     User    @relation("CidadaoCreatedBy", fields: [createdById], references: [id])
  /// Qual unidade fez o primeiro cadastro: 'medico' | 'capacitacao' | 'esportivo' | 'recreativo'
  unitIdOrigem  String
  familiaId     String?
  familia       Familia? @relation(fields: [familiaId], references: [id], onDelete: SetNull)

  // Soft delete + LGPD anonimização (§0.9)
  deletedAt     DateTime?
  anonimizadoEm DateTime? // NULL = não anonimizado

  /// Ciclo de vida do cadastro (Plano 4): rascunho → ativo quando triagem aprova ≥1 unidade.
  /// Default 'ativo' pra não quebrar fichas existentes/seedadas (que entraram direto).
  statusCadastro StatusCadastro @default(ativo)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enderecos    Endereco[]
  anexos       AnexoCidadao[]
  triagens     Triagem[]
  agendamentos Agendamento[]
  consultas    Consulta[]
  notasEvolucao NotaEvolucao[]
  matriculas   Matricula[]
  encaminhamentos Encaminhamento[]
  consentimentos Consentimento[]

  @@index([cpf])
  @@index([nomeCompleto])
  @@index([familiaId])
  @@index([unitIdOrigem])
  @@index([deletedAt])
  @@index([statusCadastro])
}

enum TipoConsentimento {
  tratamento_dados
  imagem
}

/// LGPD base legal — consentimento versionado por cidadão. 1 registro vigente por tipo
/// (upsert ao re-registrar; revogadoEm marca revogação). Imagem usa escopos granulares.
model Consentimento {
  id             String            @id @default(cuid())
  cidadaoId      String
  cidadao        Cidadao           @relation(fields: [cidadaoId], references: [id], onDelete: Cascade)
  tipo           TipoConsentimento
  versao         String // versão do termo aceito (congela mesmo se o texto mudar)
  imagemInterno  Boolean           @default(false)
  imagemRedes    Boolean           @default(false)
  imagemImprensa Boolean           @default(false)
  registradoPor  String // userId
  registradoEm   DateTime          @default(now())
  revogadoEm     DateTime?
  updatedAt      DateTime          @updatedAt

  @@unique([cidadaoId, tipo])
  @@index([cidadaoId])
}

/// Endereços 1:N por Cidadao — §0.3. Auto-preenche via BrasilAPI ao digitar CEP.
model Endereco {
  id              String   @id @default(cuid())
  cidadaoId       String
  cidadao         Cidadao  @relation(fields: [cidadaoId], references: [id], onDelete: Cascade)
  tipo            String   // 'residencial' | 'trabalho' | 'contato'
  cep             String   // 8 dígitos normalizado
  logradouro      String
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String
  uf              String   // 2 letras (ex: 'RJ')
  pontoReferencia String?
  isPrincipal     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([cidadaoId])
  @@index([cep])
}

/// Anexos do Cidadão — §0.5. PDF/JPG/PNG only, max 10MB/file, 100MB/total.
/// Armazenamento MinIO bucket 'ifp-cidadao-anexos', naming por hash SHA-256.
model AnexoCidadao {
  id            String    @id @default(cuid())
  cidadaoId     String
  cidadao       Cidadao   @relation(fields: [cidadaoId], references: [id], onDelete: Cascade)
  fileName      String    // nome original do upload
  mimeType      String    // 'application/pdf' | 'image/jpeg' | 'image/png'
  sizeBytes     Int
  hashSha256    String    // pra deduplicação + naming
  storageBucket String    @default("ifp-cidadao-anexos")
  storageKey    String    // path no MinIO (ex: "{cidadaoId}/{hash}.pdf")
  descricao     String?
  uploadedById  String
  uploadedBy    User      @relation("AnexoUploadedBy", fields: [uploadedById], references: [id])
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([cidadaoId])
  @@index([hashSha256])
}

// Plano 4 — Núcleo de Triagem Social (fatia estrutural)
// Spec: docs/superpowers/specs/2026-05-24-plano4-triagem-estrutura-design.md

enum StatusCadastro {
  rascunho
  ativo
  inativo
}

enum StatusTriagem {
  aberta
  concluida
}

enum StatusElegibilidade {
  pendente
  aprovado
  negado
  encaminhado
}

/// Triagem Social = a entrevista da assistente social com o cidadão (1º contato no funil).
/// Define aptidão e a elegibilidade por unidade. Situação socioeconômica estruturada
/// continua no Cidadao (fonte única); aqui ficam parecer + observações + extras flexíveis.
model Triagem {
  id                 String        @id @default(cuid())
  cidadaoId          String
  cidadao            Cidadao       @relation(fields: [cidadaoId], references: [id], onDelete: Cascade)
  assistenteSocialId String
  assistenteSocial   User          @relation("TriagemAssistente", fields: [assistenteSocialId], references: [id])
  dataEntrevista     DateTime?
  parecer            String?       @db.Text
  observacoes        String?       @db.Text
  situacaoSocio      Json? // extras flexíveis; estruturado (renda etc.) fica no Cidadao
  status             StatusTriagem @default(aberta)
  createdAt          DateTime      @default(now())
  closedAt           DateTime?

  elegibilidades ElegibilidadeUnidade[]

  @@index([cidadaoId, createdAt])
  @@index([status, createdAt])
}

/// Decisão de elegibilidade de uma triagem para uma unidade específica.
/// Decidida manualmente pela assistente social (regras automáticas = fatia futura, domínio Regina).
model ElegibilidadeUnidade {
  id            String              @id @default(cuid())
  triagemId     String
  triagem       Triagem             @relation(fields: [triagemId], references: [id], onDelete: Cascade)
  unidade       String // 'medico' | 'capacitacao' | 'esportivo' | 'recreativo'
  status        StatusElegibilidade @default(pendente)
  motivo        String?             @db.Text
  decididoPorId String?
  decididoPor   User?               @relation("ElegibilidadeDecidida", fields: [decididoPorId], references: [id])
  decididoEm    DateTime?

  @@unique([triagemId, unidade])
  @@index([unidade, status])
}

// Funil de captação — Fatia A (agendamento interno)
// Spec: docs/superpowers/specs/2026-05-25-funnel-agendamento-whatsapp-design.md

enum StatusVaga {
  aberta
  pausada
  encerrada
}

enum StatusAgendamento {
  agendado
  confirmado
  realizado
  cancelado
  faltou
}

/// Vaga liberada por uma unidade — capacidade (slotsTotais) + janela de divulgação.
model Vaga {
  id          String     @id @default(cuid())
  unidade     String // 'medico' | 'capacitacao' | 'esportivo' | 'recreativo'
  titulo      String
  descricao   String?    @db.Text
  slotsTotais Int        @default(0)
  abreEm      DateTime?
  fechaEm     DateTime?
  status      StatusVaga @default(aberta)
  criadoPorId String
  criadoPor   User       @relation("VagaCriadaPor", fields: [criadoPorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  agendamentos Agendamento[]

  @@index([unidade, status])
}

/// Agendamento de entrevista de um interessado (pode ainda NÃO ser Cidadao).
/// `cidadaoId` é setado quando a ficha é criada a partir do agendamento (materialização).
model Agendamento {
  id              String            @id @default(cuid())
  vagaId          String
  vaga            Vaga              @relation(fields: [vagaId], references: [id], onDelete: Cascade)
  nomeInteressado String
  telefone        String
  horario         DateTime
  status          StatusAgendamento @default(agendado)
  consenteContato Boolean           @default(false)
  observacoes     String?           @db.Text
  criadoPorId     String?
  criadoPor       User?             @relation("AgendamentoCriadoPor", fields: [criadoPorId], references: [id])
  cidadaoId       String?
  cidadao         Cidadao?          @relation(fields: [cidadaoId], references: [id], onDelete: SetNull)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([vagaId, status])
  @@index([cidadaoId])
}

// ============================================================================
// F1.B.1 — Centro Médico: agenda + fila do dia
// Spec: docs/superpowers/specs/2026-05-28-medico-agenda-fila-design.md
// ============================================================================

model Especialidade {
  id               String                       @id @default(cuid())
  nome             String                       @unique
  duracaoPadraoMin Int
  corDestaque      String // hex do brandbook, ex: "#007571"
  ativa            Boolean                      @default(true)
  profissionais    ProfissionalEspecialidade[]
  templates        AgendaTemplate[]
  slots            Slot[]
  consultas        Consulta[]
  encaminhamentos  Encaminhamento[]
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
}

model Profissional {
  id             String                       @id @default(cuid())
  userId         String                       @unique
  user           User                         @relation(fields: [userId], references: [id], onDelete: Restrict)
  nomeExibicao   String
  conselho       String
  nroConselho    String
  bio            String?
  fotoUrl        String?
  ativo          Boolean                      @default(true)
  especialidades ProfissionalEspecialidade[]
  templates      AgendaTemplate[]
  slots          Slot[]
  consultas      Consulta[]
  notasEvolucao  NotaEvolucao[]
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
}

model ProfissionalEspecialidade {
  profissionalId  String
  especialidadeId String
  profissional    Profissional  @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  especialidade   Especialidade @relation(fields: [especialidadeId], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())

  @@id([profissionalId, especialidadeId])
  @@index([especialidadeId])
}

model AgendaTemplate {
  id              String        @id @default(cuid())
  profissionalId  String
  especialidadeId String
  profissional    Profissional  @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  especialidade   Especialidade @relation(fields: [especialidadeId], references: [id], onDelete: Restrict)
  // diasSemana: 0=domingo, 1=segunda, ..., 6=sábado. Array de Int[].
  diasSemana      Int[]
  faixaInicio     String // "HH:mm" formato 24h
  faixaFim        String // "HH:mm"
  duracaoSlotMin  Int
  validoDe        DateTime
  validoAte       DateTime?
  observacoes     String?
  ativo           Boolean      @default(true)
  slots           Slot[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([profissionalId, ativo])
  @@index([especialidadeId])
}

enum StatusSlot {
  disponivel
  reservado
  bloqueado
  realizado
  faltou
  cancelado
}

model Slot {
  id              String          @id @default(cuid())
  profissionalId  String
  especialidadeId String
  templateId      String?
  dataHoraInicio  DateTime
  duracaoMin      Int
  status          StatusSlot      @default(disponivel)
  motivoBloqueio  String?
  profissional    Profissional    @relation(fields: [profissionalId], references: [id], onDelete: Restrict)
  especialidade   Especialidade   @relation(fields: [especialidadeId], references: [id], onDelete: Restrict)
  template        AgendaTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  consulta        Consulta?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([profissionalId, dataHoraInicio])
  @@index([status, dataHoraInicio])
  @@index([especialidadeId, status, dataHoraInicio])
}

enum StatusConsulta {
  agendada
  confirmada
  em_atendimento
  realizada
  faltou
  cancelada
}

enum StatusEncaminhamento {
  aguardando_agendamento
  agendado
  cancelado
}

model Consulta {
  id                     String         @id @default(cuid())
  slotId                 String         @unique
  cidadaoId              String
  profissionalId         String
  especialidadeId        String
  status                 StatusConsulta @default(agendada)
  observacoesAgendamento String?
  origemTriagemId        String?
  origemEncaminhamentoId String?
  cancelMotivo           String?
  checkinEm              DateTime? // recepção marcou a chegada do paciente (check-in)
  createdBy              String // userId
  slot                   Slot           @relation(fields: [slotId], references: [id], onDelete: Restrict)
  cidadao                Cidadao        @relation(fields: [cidadaoId], references: [id], onDelete: Restrict)
  profissional           Profissional   @relation(fields: [profissionalId], references: [id], onDelete: Restrict)
  especialidade          Especialidade  @relation(fields: [especialidadeId], references: [id], onDelete: Restrict)
  notaEvolucao           NotaEvolucao?
  origemEncaminhamento   Encaminhamento?  @relation("ConsultaOrigemEncaminhamento", fields: [origemEncaminhamentoId], references: [id], onDelete: SetNull)
  encaminhamentosOrigem  Encaminhamento[] @relation("EncaminhamentoConsultaOrigem")
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([profissionalId, status])
  @@index([cidadaoId])
  @@index([status, createdAt])
  @@index([createdBy])
  @@index([origemTriagemId])
  @@index([origemEncaminhamentoId])
}

/// F1.B — pedido do GP para especialista. Vira fila de busca ativa no callcenter.
/// Máquina de estados em lib/medico/encaminhamento.ts (espelha matricula.ts).
model Encaminhamento {
  id               String               @id @default(cuid())
  cidadaoId        String
  consultaOrigemId String
  especialidadeId  String
  motivo           String?              @db.Text
  status           StatusEncaminhamento @default(aguardando_agendamento)
  createdBy        String // userId do profissional que pediu
  canceladoMotivo  String?

  cidadao            Cidadao       @relation(fields: [cidadaoId], references: [id], onDelete: Restrict)
  consultaOrigem     Consulta      @relation("EncaminhamentoConsultaOrigem", fields: [consultaOrigemId], references: [id], onDelete: Restrict)
  especialidade      Especialidade @relation(fields: [especialidadeId], references: [id], onDelete: Restrict)
  consultasAgendadas Consulta[]    @relation("ConsultaOrigemEncaminhamento")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([cidadaoId])
  @@index([createdBy])
  @@index([consultaOrigemId])
}

// ============================================================
// F1.B.2 — Prontuário Médico (evolução + sinais vitais + CID-10)
// ============================================================

enum StatusNota {
  rascunho
  assinada
}

/// Nota clínica de evolução. 1:1 com Consulta (§0.2). Unidade do prontuário.
/// Imutável após assinatura (§0.3/§0.4); correções via AddendoNota (append-only).
model NotaEvolucao {
  id             String     @id @default(cuid())
  consultaId     String     @unique
  cidadaoId      String
  profissionalId String

  // §0.1 — formato híbrido: evolução em texto livre + blocos estruturados opcionais
  texto          String?    @db.Text

  // §0.5 — sinais vitais (todos opcionais; IMC derivado, NÃO persistido)
  paSistolica    Int?
  paDiastolica   Int?
  fcBpm          Int?
  frIrpm         Int?
  tempC          Decimal?   @db.Decimal(4, 1)
  pesoKg         Decimal?   @db.Decimal(5, 2)
  alturaCm       Int?
  spo2           Int?

  // §0.3/§0.4 — ciclo de vida da assinatura
  status         StatusNota @default(rascunho)
  assinadaEm     DateTime?
  assinadaPor    String? // userId (= profissional dono)

  consulta     Consulta          @relation(fields: [consultaId], references: [id], onDelete: Restrict)
  cidadao      Cidadao           @relation(fields: [cidadaoId], references: [id], onDelete: Restrict)
  profissional Profissional      @relation(fields: [profissionalId], references: [id], onDelete: Restrict)
  diagnosticos DiagnosticoNota[]
  addendos     AddendoNota[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cidadaoId, createdAt])
  @@index([profissionalId])
}

/// §0.4 — correção/complemento append-only de nota assinada. Nunca reescreve o original.
model AddendoNota {
  id        String       @id @default(cuid())
  notaId    String
  autorId   String // userId
  texto     String       @db.Text
  nota      NotaEvolucao @relation(fields: [notaId], references: [id], onDelete: Restrict)
  createdAt DateTime     @default(now())

  @@index([notaId, createdAt])
}

/// §0.6 — CID-10 por nota. `principal` marca o diagnóstico principal.
/// codigoCid aceita null; descricao é texto livre OU descrição do CID (fallback).
model DiagnosticoNota {
  id        String       @id @default(cuid())
  notaId    String
  codigoCid String? // ex. "J06.9"
  descricao String
  principal Boolean      @default(false)
  nota      NotaEvolucao @relation(fields: [notaId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([notaId])
  @@index([codigoCid])
}

/// §0.6 — tabela de referência CID-10 (seed do CSV DATASUS). Read-only.
model Cid10 {
  codigo    String  @id
  descricao String
  capitulo  String?

  @@index([descricao])
}

// ============================================================
// F1.A.1 — Capacitação (Catálogo + Turma + Matrícula)
// ============================================================

/// §0.1 — Curso = template reutilizável; Turmas datadas são instâncias dele.
model Curso {
  id                String   @id @default(cuid())
  nome              String
  descricao         String?  @db.Text
  area              String
  cargaHorariaTotal Int
  modalidade        String   @default("presencial") // presencial | online | hibrido
  capacidadePadrao  Int      @default(20)
  thumbUrl          String?
  ativo             Boolean  @default(true) // soft-delete
  turmas            Turma[]
  createdById       String
  createdBy         User     @relation("CursoCriadoPor", fields: [createdById], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([ativo, area])
}

/// §0.4 — Instrutor. userId nullable: null = ainda sem login (F1.A.1); login = F1.A.2.
model Instrutor {
  id           String   @id @default(cuid())
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  nomeExibicao String
  bio          String?  @db.Text
  ativo        Boolean  @default(true)
  turmas       Turma[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum StatusTurma {
  planejada
  inscricoes_abertas
  em_andamento
  concluida
  cancelada
}

/// §0.1 — Turma = instância datada de um Curso. Soft-delete da turma = status=cancelada.
model Turma {
  id          String      @id @default(cuid())
  cursoId     String
  curso       Curso       @relation(fields: [cursoId], references: [id], onDelete: Restrict)
  instrutorId String?
  instrutor   Instrutor?  @relation(fields: [instrutorId], references: [id], onDelete: SetNull)
  codigo      String      @unique
  dataInicio  DateTime    @db.Date
  dataFim     DateTime    @db.Date
  local       String?
  capacidade  Int
  status      StatusTurma @default(planejada)
  observacoes String?     @db.Text
  matriculas  Matricula[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([cursoId, status])
  @@index([status, dataInicio])
}

enum StatusMatricula {
  inscrito
  confirmado
  cursando
  concluido
  reprovado
  desistente
  lista_espera
  cancelado
}

/// §0.2 reusa Cidadao via cidadaoId; §0.7 máquina de estados completa.
model Matricula {
  id              String          @id @default(cuid())
  turmaId         String
  turma           Turma           @relation(fields: [turmaId], references: [id], onDelete: Restrict)
  cidadaoId       String
  cidadao         Cidadao         @relation(fields: [cidadaoId], references: [id], onDelete: Restrict)
  presencas       Presenca[]
  certificado     Certificado?
  status          StatusMatricula @default(inscrito)
  origemTriagemId String?
  observacoes     String?         @db.Text
  motivoSaida     String?
  createdBy       String // userId
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([turmaId, cidadaoId])
  @@index([turmaId, status])
  @@index([cidadaoId])
  @@index([createdBy])
  @@index([origemTriagemId])
}

/// F1.A.2 — Presença na aula. Uma marcação por matrícula por dia (upsert idempotente).
model Presenca {
  id            String    @id @default(cuid())
  matriculaId   String
  matricula     Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  data          DateTime  @db.Date
  presente      Boolean   @default(true)
  registradoPor String // userId
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([matriculaId, data])
  @@index([matriculaId])
}

/// F1.A.3 — Certificado de conclusão. 1 por matrícula. Snapshots (nomeAluno/nomeCurso/
/// cargaHoraria) p/ o documento não mudar se curso/turma forem editados depois.
model Certificado {
  id                   String    @id @default(cuid())
  matriculaId          String    @unique
  matricula            Matricula @relation(fields: [matriculaId], references: [id], onDelete: Cascade)
  codigo               String    @unique // código público de verificação
  nomeAluno            String
  nomeCurso            String
  cargaHoraria         Int
  percentualFrequencia Int
  emitidoPor           String // userId
  emitidoEm            DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

/// F1.B.3 — Receita médica. consultaId/profissionalId como FK simples (sem relação Prisma)
/// + snapshots, p/ o documento impresso não mudar se a consulta/profissional forem editados.
model Receita {
  id               String        @id @default(cuid())
  consultaId       String
  profissionalId   String
  nomePaciente     String
  nomeProfissional String
  conselho         String // ex.: CRM-RJ
  nroConselho      String
  observacoes      String?       @db.Text
  itens            ReceitaItem[]
  emitidoEm        DateTime      @default(now())
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([consultaId])
}

model ReceitaItem {
  id          String  @id @default(cuid())
  receitaId   String
  receita     Receita @relation(fields: [receitaId], references: [id], onDelete: Cascade)
  medicamento String
  posologia   String
  quantidade  String?
  via         String?

  @@index([receitaId])
}

/// F1.B.3 — Atestado / declaração de comparecimento. FK simples + snapshots. CID opcional (sigilo).
model Atestado {
  id               String   @id @default(cuid())
  consultaId       String
  profissionalId   String
  nomePaciente     String
  nomeProfissional String
  conselho         String
  nroConselho      String
  diasAfastamento  Int?
  cid              String?
  observacao       String?  @db.Text
  emitidoEm        DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([consultaId])
}
