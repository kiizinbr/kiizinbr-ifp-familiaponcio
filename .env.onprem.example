# ============================================================
# IFP Connect — Variaveis para deploy on-prem (LAN interna)
# Copie para .env.production no servidor e ajuste.
# Sempre rode com:
#   docker compose -f docker-compose.prod.yml -f docker-compose.onprem.yml \
#                  --env-file .env.production up -d
# ============================================================

# Postgres (interno ao docker network)
POSTGRES_USER=ifp
POSTGRES_PASSWORD=__GERAR_COM__openssl_rand_-base64_32__
POSTGRES_DB=ifp_connect

# Redis (interno ao docker network)
REDIS_PASSWORD=__GERAR_COM__openssl_rand_-base64_32__

# Dominios internos da LAN (adicionar entradas em /etc/hosts dos clientes ou
# configurar DNS local apontando para o IP da VM)
WEB_DOMAIN=ifp.lan
API_DOMAIN=api.ifp.lan
WEB_ORIGIN=http://ifp.lan

# Auth — gerar cada um com: openssl rand -base64 32
JWT_SECRET=__TROCAR__
JWT_EXPIRES_IN=8h
NEXTAUTH_SECRET=__TROCAR__

# Sem Let's Encrypt em LAN — o override docker-compose.onprem.yml ja seta
# ACME_EMAIL como placeholder, mas voce pode deixar aqui se preferir.
ACME_EMAIL=admin@ifp.local

# Seed do Super Admin (so usado no primeiro `db:seed`; depois pode remover).
SEED_SUPER_ADMIN_EMAIL=admin@ifp.local
SEED_SUPER_ADMIN_PASSWORD=__TROCAR__
