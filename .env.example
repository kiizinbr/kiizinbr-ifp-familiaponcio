# ============================================================
# IFP Connect — Variáveis de ambiente (exemplo)
# Copie para .env (raiz) e ajuste para seu ambiente local.
# Nunca commitar .env real (.gitignore já cobre).
# ============================================================

# Postgres
DATABASE_URL="postgresql://ifp:ifp@localhost:5432/ifp_connect?schema=public"

# API (NestJS)
PORT=3333
WEB_ORIGIN="http://localhost:3000"
JWT_SECRET="troque-por-string-aleatoria-32-bytes"
JWT_EXPIRES_IN="8h"

# Auth.js (Next.js) — usa a mesma string como NEXTAUTH_SECRET é uma OPÇÃO,
# mas para isolar superficie de ataque o ideal é gerar valores distintos.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-por-string-aleatoria-32-bytes"
API_URL="http://localhost:3333/api/v1"

# Resend (magic link)
RESEND_API_KEY=""

# Seed (opcional — se não setar, seed não cria Super Admin)
SEED_SUPER_ADMIN_EMAIL="admin@ifp.local"
SEED_SUPER_ADMIN_PASSWORD=""
