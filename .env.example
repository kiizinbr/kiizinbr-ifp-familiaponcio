# ============================================================
# IFP Connect — Variáveis de ambiente (exemplo)
# Copie para .env (raiz) e ajuste para seu ambiente local.
# Nunca commitar .env real (.gitignore já cobre).
# ============================================================

# Postgres
DATABASE_URL="postgresql://ifp:ifp@localhost:5432/ifp_connect?schema=public"

# API (NestJS)
PORT=3333
WEB_ORIGIN="http://localhost:3000"
JWT_SECRET="troque-por-string-aleatoria-32-bytes"
JWT_EXPIRES_IN="8h"

# Auth.js (Next.js) — usa a mesma string como NEXTAUTH_SECRET é uma OPÇÃO,
# mas para isolar superficie de ataque o ideal é gerar valores distintos.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-por-string-aleatoria-32-bytes"
# API_URL é usada no servidor (Auth.js). NEXT_PUBLIC_API_URL é exposta ao browser
# (as telas do Serviço Social chamam a API direto via useAuthFetch).
API_URL="http://localhost:3333/api/v1"
NEXT_PUBLIC_API_URL="http://localhost:3333/api/v1"

# Recuperação de senha é admin-driven (sem e-mail/WhatsApp). Ver docs/DECISOES-PRODUCAO.md.
# (Nenhuma variável de envio de e-mail é necessária — não há provider configurado.)

# Seed (opcional — se não setar, seed não cria Super Admin)
SEED_SUPER_ADMIN_EMAIL="admin@ifp.local"
SEED_SUPER_ADMIN_PASSWORD=""
SEED_MEDICO_PASSWORD="defina-uma-senha-dev" # seed da medica de exemplo (Centro Medico)

# MinIO / S3 — storage de documentos e fotos (Onda C).
# Em dev: MinIO via Docker (http, sem SSL). Em prod: endpoint S3/R2 com SSL.
# NUNCA commitar a secret real — preencha no .env local.
MINIO_ENDPOINT="127.0.0.1"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="troque-pela-access-key"
MINIO_SECRET_KEY="troque-pela-secret-key"
MINIO_BUCKET="ifp-documentos"
