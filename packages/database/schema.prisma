// ============================================================
// IFP Connect — Schema Prisma (esboço inicial Fase 0)
// Instituto Família Poncio
//
// Princípios de design:
// - Multi-tenant LÓGICO: toda tabela operacional tem tenant_id (Unidade).
//   Tabelas globais (User, FichaCidada) NÃO têm tenant_id, mas seu
//   acesso é mediado por relações + RBAC + Row-Level Security no Postgres.
// - Ficha Cidadã é GLOBAL: o mesmo cidadão pode ser beneficiário em
//   múltiplas unidades. A elegibilidade por unidade fica em
//   ElegibilidadePorUnidade (tabela de junção).
// - Sigilo: prontuário clínico, fichas pedagógicas e dados sensíveis
//   ficam em tabelas próprias de cada módulo (a serem criadas em
//   migrations futuras) e SEMPRE vinculados a uma Unidade.
// - LGPD: AuditLog registra leituras e escritas em dados sensíveis.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Tenancy / Unidades
// ============================================================

enum TipoUnidade {
  MEDICO
  CAPACITACAO
  ESPORTIVO
  EDUCACIONAL
}

model Unidade {
  id           String      @id @default(cuid())
  tipo         TipoUnidade @unique
  nome         String
  slug         String      @unique // "medico", "capacitacao", "esportivo", "educacional"
  endereco     String?
  telefone     String?
  email        String?
  ativo        Boolean     @default(true)
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt

  usuarios             UsuarioUnidade[]
  elegibilidades       ElegibilidadePorUnidade[]
  profissionais        Profissional[]
  agendamentos         Agendamento[]
  atendimentos         Atendimento[]
  cursos               Curso[]
  turmas               Turma[]
  matriculas           Matricula[]
  aulas                Aula[]
  certificados         Certificado[]
  turmasInfantis       TurmaInfantil[]
  matriculasInfantis   MatriculaInfantil[]
  checksInOut          CheckInOut[]
  diariosDia           DiarioDia[]
  comunicados          Comunicado[]
  modalidades          Modalidade[]
  turmasEsportivas     TurmaEsportiva[]
  matriculasEsportivas MatriculaEsportiva[]
  graduacoes           Graduacao[]
  conversasFamilia     ConversaFamilia[]
  treinosEsportivos    TreinoEsportivo[]
  prescricoes          Prescricao[]
  eventos              EventoUnidade[]

  encaminhamentosOrigem  Encaminhamento[]   @relation("EncaminhamentoOrigem")
  encaminhamentosDestino Encaminhamento[]   @relation("EncaminhamentoDestino")
  sinalizacoesPonte      SinalizacaoPonte[] @relation("SinalizacaoOrigem")

  @@map("unidades")
}

// ============================================================
// Usuários e RBAC
// ============================================================

enum Perfil {
  SUPER_ADMIN
  PRESIDENCIA
  SERVICO_SOCIAL
  GESTOR_UNIDADE
  PROFISSIONAL
  RECEPCAO
  RESPONSAVEL_FAMILIAR
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  senhaHash          String? // null se usar magic link / SSO
  nome               String
  cpf                String?   @unique
  ativo              Boolean   @default(true)
  // Primeiro acesso: senha provisória definida pelo admin/gestor. Enquanto true,
  // o login obriga o usuário a trocar a senha antes de usar o sistema.
  mustChangePassword Boolean   @default(false)
  ultimoLogin        DateTime?
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  perfis           UsuarioPerfil[]
  unidades         UsuarioUnidade[]
  fichaCidada      FichaCidada?      @relation("UserToFichaCidada", fields: [fichaCidadaId], references: [id])
  fichaCidadaId    String?           @unique
  profissional     Profissional?
  mensagensFamilia MensagemFamilia[]

  @@map("usuarios")
}

// Um usuário pode ter mais de um perfil (ex.: médico que também é gestor)
model UsuarioPerfil {
  id     String @id @default(cuid())
  userId String
  perfil Perfil

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, perfil])
  @@map("usuarios_perfis")
}

// Usuário pode atuar em N unidades (raro, mas existe)
model UsuarioUnidade {
  id        String @id @default(cuid())
  userId    String
  unidadeId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  unidade Unidade @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  @@unique([userId, unidadeId])
  @@map("usuarios_unidades")
}

// ============================================================
// Ficha Cidadã — núcleo do Serviço Social
// ============================================================

enum EstadoCivil {
  SOLTEIRO
  CASADO
  UNIAO_ESTAVEL
  DIVORCIADO
  VIUVO
}

enum SituacaoMoradia {
  PROPRIA
  ALUGADA
  CEDIDA
  FINANCIADA
  OCUPACAO
  OUTRA
}

enum Escolaridade {
  SEM_ESCOLARIDADE
  FUND_INCOMPLETO
  FUND_COMPLETO
  MEDIO_INCOMPLETO
  MEDIO_COMPLETO
  SUPERIOR_INCOMPLETO
  SUPERIOR_COMPLETO
  POS_GRADUACAO
}

model FichaCidada {
  id        String @id @default(cuid())
  protocolo String @unique // ex.: "IFP-2025-000123"

  // Dados do titular (responsável familiar)
  nomeCompleto   String
  cpf            String        @unique
  rg             String?
  dataNascimento DateTime
  estadoCivil    EstadoCivil?
  escolaridade   Escolaridade?
  fotoUrl        String?

  // Contato
  telefone      String
  telefoneAlt   String?
  email         String?
  whatsappOptIn Boolean @default(false)

  // Endereço
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String  @default("Duque de Caxias")
  uf          String  @default("RJ")

  // Status geral
  ativa       Boolean @default(true)
  observacoes String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  user User? @relation("UserToFichaCidada")

  membros                 MembroFamiliar[]
  dadosSocio              DadosSocioeconomicos?
  documentos              Documento[]
  entrevistas             Entrevista[]
  elegibilidades          ElegibilidadePorUnidade[]
  consentimentos          Consentimento[]
  agendamentos            Agendamento[]
  atendimentos            Atendimento[]
  alergias                Alergia[]
  condicoesCronicas       CondicaoCronica[]
  matriculas              Matricula[]
  autorizacoesImagem      AutorizacaoImagem[]
  matriculasInfantis      MatriculaInfantil[]
  responsaveisAutorizados ResponsavelAutorizado[]
  comunicadosLeituras     ComunicadoLeitura[]
  matriculasEsportivas    MatriculaEsportiva[]
  conversasFamilia        ConversaFamilia[]
  prescricoes             Prescricao[]
  triagens                Triagem[]
  encaminhamentos         Encaminhamento[]
  sinalizacoesPonte       SinalizacaoPonte[]
  confirmacoesEvento      ConfirmacaoEvento[]
  presencasCreche         PresencaCreche[]

  // Painel da Presidência: contagens por ativa / novas por criadoEm
  @@index([ativa])
  @@index([criadoEm])
  @@map("fichas_cidadas")
}

enum Parentesco {
  CONJUGE
  FILHO
  FILHA
  ENTEADO
  PAI
  MAE
  IRMAO
  IRMA
  AVO
  AVOH
  NETO
  NETA
  OUTRO
}

model MembroFamiliar {
  id             String        @id @default(cuid())
  fichaId        String
  nomeCompleto   String
  cpf            String?
  dataNascimento DateTime
  parentesco     Parentesco
  ocupacao       String?
  escolaridade   Escolaridade?
  rendaMensal    Decimal?      @db.Decimal(10, 2)
  observacoes    String?

  ficha FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  agendamentos            Agendamento[]
  atendimentos            Atendimento[]
  alergias                Alergia[]
  condicoesCronicas       CondicaoCronica[]
  matriculas              Matricula[]
  autorizacoesImagem      AutorizacaoImagem[]
  matriculasInfantis      MatriculaInfantil[]
  responsaveisAutorizados ResponsavelAutorizado[]
  checksInOut             CheckInOut[]
  diariosDia              DiarioDia[]
  matriculasEsportivas    MatriculaEsportiva[]
  conversa                ConversaFamilia?
  prescricoes             Prescricao[]
  sinalizacoesPonte       SinalizacaoPonte[]
  confirmacoesEvento      ConfirmacaoEvento[]
  presencasCreche         PresencaCreche[]

  @@map("membros_familiares")
}

model DadosSocioeconomicos {
  id      String @id @default(cuid())
  fichaId String @unique

  rendaFamiliarTotal Decimal @db.Decimal(10, 2)
  rendaPerCapita     Decimal @db.Decimal(10, 2)
  recebeBolsaFamilia Boolean @default(false)
  recebeBPC          Boolean @default(false)
  recebeAuxilioGas   Boolean @default(false)
  outrosBeneficios   String?

  situacaoMoradia      SituacaoMoradia
  numeroPessoasMoradia Int
  numeroComodos        Int?
  temAguaEncanada      Boolean         @default(true)
  temEsgoto            Boolean         @default(true)
  temEnergiaEletrica   Boolean         @default(true)

  vulnerabilidades String? // texto livre da assistente social

  atualizadoEm DateTime @updatedAt

  ficha FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  @@map("dados_socioeconomicos")
}

enum TipoDocumento {
  RG
  CPF
  COMPROVANTE_RESIDENCIA
  COMPROVANTE_RENDA
  CADUNICO
  CARTEIRA_TRABALHO
  CERTIDAO_NASCIMENTO
  LAUDO_MEDICO
  OUTRO
}

model Documento {
  id           String        @id @default(cuid())
  fichaId      String
  tipo         TipoDocumento
  nomeArquivo  String
  url          String // S3 / R2 / MinIO
  tamanhoBytes Int
  mimeType     String
  enviadoPor   String? // userId
  enviadoEm    DateTime      @default(now())

  ficha FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  @@map("documentos")
}

model Entrevista {
  id           String    @id @default(cuid())
  fichaId      String
  realizadaPor String // userId do assistente social
  realizadaEm  DateTime
  resumo       String // markdown
  proximaEm    DateTime? // reavaliação agendada

  ficha FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  @@map("entrevistas")
}

enum StatusElegibilidade {
  PENDENTE
  APROVADO
  REPROVADO
  SUSPENSO
  DESLIGADO
}

model ElegibilidadePorUnidade {
  id           String              @id @default(cuid())
  fichaId      String
  unidadeId    String
  status       StatusElegibilidade @default(PENDENTE)
  avaliadoPor  String? // userId do assistente
  avaliadoEm   DateTime?
  motivo       String?
  reavaliarEm  DateTime?
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt

  ficha   FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  unidade Unidade     @relation(fields: [unidadeId], references: [id], onDelete: Cascade)

  @@unique([fichaId, unidadeId])
  // Painel da Presidência: filtros por status / status+unidade / criadoEm
  @@index([status])
  @@index([status, unidadeId])
  @@index([criadoEm])
  @@map("elegibilidades")
}

enum TipoConsentimento {
  USO_DADOS_LGPD
  USO_IMAGEM
  COMUNICACAO_WHATSAPP
  COMUNICACAO_EMAIL
  COMPARTILHAMENTO_PARCEIROS
}

model Consentimento {
  id           String            @id @default(cuid())
  fichaId      String
  tipo         TipoConsentimento
  concedido    Boolean
  versaoTermo  String // versão do termo aceito
  ip           String?
  userAgent    String?
  registradoEm DateTime          @default(now())

  ficha FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  @@unique([fichaId, tipo, versaoTermo])
  @@map("consentimentos")
}

// ============================================================
// Auditoria (LGPD)
// ============================================================

enum AcaoAuditoria {
  CREATE
  READ
  UPDATE
  DELETE
  EXPORT
  LOGIN
  LOGOUT
}

model AuditLog {
  id         String        @id @default(cuid())
  userId     String?
  acao       AcaoAuditoria
  entidade   String // ex.: "FichaCidada"
  entidadeId String?
  ip         String?
  userAgent  String?
  metadados  Json?
  criadoEm   DateTime      @default(now())

  @@index([userId])
  @@index([entidade, entidadeId])
  @@index([criadoEm])
  @@map("audit_logs")
}

// ============================================================
// Centro Médico (Fase 1 — vertical do atendimento)
// ============================================================
// - Autoria clínica usa FK real para Profissional (integridade de prontuário);
//   campos administrativos (criadoPor, registradosPor) seguem o padrão String.
// - Atendimento é imutável após encerradoEm ("selo") — bloqueio na aplicação.
// - Alergia/CondicaoCronica penduram na FichaCidada (histórico do cidadão,
//   atravessa unidades — mesmo racional da ficha global).

enum StatusAgendamento {
  AGENDADO
  CONFIRMADO
  EM_ATENDIMENTO
  CONCLUIDO
  FALTOU
  CANCELADO
}

enum GravidadeAlergia {
  LEVE
  MODERADA
  GRAVE
}

model Profissional {
  id               String   @id @default(cuid())
  userId           String   @unique
  unidadeId        String
  registroConselho String? // CRM/COREN — opcional: instrutor não tem conselho
  ufConselho       String   @default("RJ")
  especialidade    String?
  ativo            Boolean  @default(true)
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  user              User              @relation(fields: [userId], references: [id])
  unidade           Unidade           @relation(fields: [unidadeId], references: [id])
  agendamentos      Agendamento[]
  atendimentos      Atendimento[]
  turmas            Turma[]
  aulas             Aula[]
  turmasInfantis    TurmaInfantil[]
  checksRegistrados CheckInOut[]
  diariosFechados   DiarioDia[]
  registrosRotina   RegistroRotina[]
  turmasEsportivas  TurmaEsportiva[]
  treinosEsportivos TreinoEsportivo[]
  prescricoes       Prescricao[]

  @@map("profissionais")
}

model Agendamento {
  id             String            @id @default(cuid())
  unidadeId      String // tenant obrigatório
  fichaId        String
  membroId       String? // dependente atendido
  profissionalId String
  inicioEm       DateTime
  fimEm          DateTime
  status         StatusAgendamento @default(AGENDADO)
  motivo         String?
  criadoPor      String? // userId de quem agendou
  criadoEm       DateTime          @default(now())
  atualizadoEm   DateTime          @updatedAt

  unidade      Unidade         @relation(fields: [unidadeId], references: [id])
  ficha        FichaCidada     @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  membro       MembroFamiliar? @relation(fields: [membroId], references: [id], onDelete: SetNull)
  profissional Profissional    @relation(fields: [profissionalId], references: [id])
  atendimento  Atendimento?

  @@index([unidadeId, inicioEm])
  @@index([profissionalId, inicioEm])
  @@map("agendamentos")
}

model Atendimento {
  id             String    @id @default(cuid())
  unidadeId      String
  fichaId        String
  membroId       String?
  profissionalId String
  agendamentoId  String?   @unique
  subjetivo      String? // S — queixa
  objetivo       String? // O — exame físico (Fase 1: texto)
  avaliacao      String? // A — hipótese diagnóstica
  plano          String? // P — conduta, atestado, retorno
  cid10          String?
  iniciadoEm     DateTime  @default(now())
  encerradoEm    DateTime? // "selo" — imutável após preenchido
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  unidade      Unidade         @relation(fields: [unidadeId], references: [id])
  ficha        FichaCidada     @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  membro       MembroFamiliar? @relation(fields: [membroId], references: [id], onDelete: SetNull)
  profissional Profissional    @relation(fields: [profissionalId], references: [id])
  agendamento  Agendamento?    @relation(fields: [agendamentoId], references: [id])
  vitais       SinaisVitais?
  prescricoes  Prescricao[]

  @@index([fichaId])
  @@index([unidadeId, iniciadoEm])
  @@index([encerradoEm]) // séries/contagens de atendimentos selados (presidência)
  @@map("atendimentos")
}

model SinaisVitais {
  id                     String   @id @default(cuid())
  unidadeId              String
  atendimentoId          String   @unique // 1-1 com o atendimento
  registradosPor         String // userId
  pressaoSistolica       Int?
  pressaoDiastolica      Int?
  frequenciaCardiaca     Int?
  frequenciaRespiratoria Int?
  temperaturaC           Decimal? @db.Decimal(4, 1)
  saturacaoO2            Int?
  pesoKg                 Decimal? @db.Decimal(5, 2)
  alturaCm               Decimal? @db.Decimal(5, 1)
  glicemia               Int?
  queixaPrincipal        String?
  registradosEm          DateTime @default(now())
  atualizadoEm           DateTime @updatedAt

  atendimento Atendimento @relation(fields: [atendimentoId], references: [id], onDelete: Cascade)

  @@map("sinais_vitais")
}

// Histórico clínico do CIDADÃO — pendurado na ficha (atravessa unidades)

model Alergia {
  id            String            @id @default(cuid())
  fichaId       String
  membroId      String?
  descricao     String // ex.: "Dipirona"
  gravidade     GravidadeAlergia?
  registradaPor String? // userId
  ativa         Boolean           @default(true)
  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt

  ficha  FichaCidada     @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  membro MembroFamiliar? @relation(fields: [membroId], references: [id], onDelete: SetNull)

  @@index([fichaId])
  @@map("alergias")
}

model CondicaoCronica {
  id              String    @id @default(cuid())
  fichaId         String
  membroId        String?
  descricao       String // ex.: "Asma"
  cid10           String?
  diagnosticadaEm DateTime?
  observacoes     String?
  ativa           Boolean   @default(true)
  criadoEm        DateTime  @default(now())
  atualizadoEm    DateTime  @updatedAt

  ficha  FichaCidada     @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  membro MembroFamiliar? @relation(fields: [membroId], references: [id], onDelete: SetNull)

  @@index([fichaId])
  @@map("condicoes_cronicas")
}

// ------------------------------------------------------------
// Prescrição médica — com bloqueio de alergia SERVER-SIDE.
// A checagem (medicamento × alergia ativa) roda no serviço usando
// alergia-check.ts; prescrever apesar de conflito exige override
// CONSCIENTE (motivo registrado). Prescrição emitida é imutável.
// ------------------------------------------------------------
model Prescricao {
  id                    String   @id @default(cuid())
  unidadeId             String
  atendimentoId         String
  fichaId               String
  membroId              String?
  profissionalId        String
  observacoes           String?
  // Trilha de segurança: prescreveu apesar de conflito de alergia?
  // o override consciente fica registrado (quem e por quê).
  alergiaOverride       Boolean  @default(false)
  alergiaOverrideMotivo String?
  emitidaEm             DateTime @default(now())
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  unidade      Unidade          @relation(fields: [unidadeId], references: [id])
  atendimento  Atendimento      @relation(fields: [atendimentoId], references: [id], onDelete: Cascade)
  ficha        FichaCidada      @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  membro       MembroFamiliar?  @relation(fields: [membroId], references: [id], onDelete: SetNull)
  profissional Profissional     @relation(fields: [profissionalId], references: [id])
  itens        PrescricaoItem[]

  @@index([atendimentoId])
  @@index([fichaId])
  @@map("prescricoes")
}

model PrescricaoItem {
  id              String   @id @default(cuid())
  prescricaoId    String
  medicamento     String // nome livre (v1) — futuro: ref. a dicionário de princípio ativo
  posologia       String // ex.: "1 comp 8/8h por 5 dias"
  conflitoAlergia Boolean  @default(false) // snapshot do alerta no momento (auditoria)
  criadoEm        DateTime @default(now())

  prescricao Prescricao @relation(fields: [prescricaoId], references: [id], onDelete: Cascade)

  @@index([prescricaoId])
  @@map("prescricao_itens")
}

// ------------------------------------------------------------
// Serviço Social — Triagem (fila de entrada das famílias)
// ------------------------------------------------------------
enum StatusTriagem {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
}

// Severidade em ordem ASC — orderBy desc traz URGENTE primeiro.
enum PrioridadeTriagem {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

model Triagem {
  id                String            @id @default(cuid())
  fichaId           String
  status            StatusTriagem     @default(PENDENTE)
  prioridade        PrioridadeTriagem @default(MEDIA)
  motivoSolicitacao String?
  iniciadaEm        DateTime?
  concluidaEm       DateTime?
  criadoPor         String? // userId de quem abriu a triagem
  criadoEm          DateTime          @default(now())
  atualizadoEm      DateTime          @updatedAt

  ficha FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)

  @@index([status, prioridade])
  @@index([fichaId])
  @@map("triagens")
}

// ------------------------------------------------------------
// Serviço Social — Encaminhamentos (workflow entre unidades) e
// Ponte (sinalizações que os profissionais enviam ao Serviço Social)
// ------------------------------------------------------------
enum StatusEncaminhamento {
  PENDENTE
  ACEITO
  RECUSADO
}

enum StatusSinalizacao {
  PENDENTE
  ATENDIDA
}

enum TipoSinalizacao {
  ENCAMINHAMENTO
  OBSERVACAO
  ALERTA
}

// Prioridade binária compartilhada por Encaminhamento e SinalizacaoPonte.
// Ordem ASC → orderBy desc traz URGENTE primeiro.
enum PrioridadeSinal {
  NORMAL
  URGENTE
}

model Encaminhamento {
  id                    String               @id @default(cuid())
  fichaId               String
  unidadeOrigemId       String
  unidadeDestinoId      String
  status                StatusEncaminhamento @default(PENDENTE)
  prioridade            PrioridadeSinal      @default(NORMAL)
  motivo                String
  justificativaResposta String? // preenchida ao recusar
  respondidoPor         String? // userId de quem aceitou/recusou
  respondidoEm          DateTime?
  criadoPor             String? // userId de quem encaminhou
  criadoEm              DateTime             @default(now())
  atualizadoEm          DateTime             @updatedAt

  ficha          FichaCidada @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  unidadeOrigem  Unidade     @relation("EncaminhamentoOrigem", fields: [unidadeOrigemId], references: [id])
  unidadeDestino Unidade     @relation("EncaminhamentoDestino", fields: [unidadeDestinoId], references: [id])

  @@index([unidadeOrigemId, status])
  @@index([unidadeDestinoId, status])
  @@index([fichaId])
  @@map("encaminhamentos")
}

model SinalizacaoPonte {
  id              String            @id @default(cuid())
  fichaId         String
  membroId        String? // sinalização pode apontar para um membro específico
  unidadeOrigemId String // unidade do profissional que sinalizou
  tipo            TipoSinalizacao   @default(ENCAMINHAMENTO)
  prioridade      PrioridadeSinal   @default(NORMAL)
  descricao       String
  status          StatusSinalizacao @default(PENDENTE)
  respondidoPor   String? // userId do social que atendeu
  respondidoEm    DateTime?
  criadoPor       String? // userId do profissional que sinalizou
  criadoEm        DateTime          @default(now())
  atualizadoEm    DateTime          @updatedAt

  ficha         FichaCidada     @relation(fields: [fichaId], references: [id], onDelete: Cascade)
  membro        MembroFamiliar? @relation(fields: [membroId], references: [id], onDelete: SetNull)
  unidadeOrigem Unidade         @relation("SinalizacaoOrigem", fields: [unidadeOrigemId], references: [id])

  @@index([unidadeOrigemId, status])
  @@index([status, criadoEm])
  @@index([fichaId])
  @@map("sinalizacoes_ponte")
}

// ============================================================
// Centro de Capacitação (Fase 3)
// ============================================================
// - Vertical "da matrícula ao certificado verificável".
// - Matricula referencia FichaCidada (titular) e opcionalmente
//   MembroFamiliar (dependente matriculado).
// - Certificado tem codigoVerificacao único para validação pública.

enum ModalidadeCurso {
  PRATICO
  TEORICO
}

enum StatusTurma {
  INSCRICOES_ABERTAS
  EM_ANDAMENTO
  ENCERRADA
}

enum StatusMatricula {
  ATIVA
  LISTA_ESPERA
  TRANCADA
  EVADIDA
  CONCLUIDA
  CANCELADA // lista de espera não atendida até o encerramento da turma (não é evasão)
}

enum StatusPresenca {
  PRESENTE
  FALTA
  JUSTIFICADA
}

model Curso {
  id                String          @id @default(cuid())
  unidadeId         String
  nome              String
  modalidade        ModalidadeCurso
  cargaHorariaTotal Int
  presencaMinimaPct Int             @default(75)
  requerModelos     Boolean         @default(false)
  ativo             Boolean         @default(true)
  criadoEm          DateTime        @default(now())
  atualizadoEm      DateTime        @updatedAt

  unidade Unidade       @relation(fields: [unidadeId], references: [id])
  turmas  Turma[]
  modulos ModuloCurso[]

  @@index([unidadeId])
  @@map("cursos")
}

// Estrutura curricular do curso (trilha): módulos ordenados, cada um com
// itens de ementa. Não afeta turmas/matrículas — é só o conteúdo do curso.
model ModuloCurso {
  id           String   @id @default(cuid())
  cursoId      String
  ordem        Int // posição na trilha (1, 2, 3...)
  nome         String
  cargaHoraria Int? // horas estimadas do módulo (opcional)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  curso Curso        @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  itens EmentaItem[]

  @@unique([cursoId, ordem])
  @@index([cursoId])
  @@map("modulos_curso")
}

model EmentaItem {
  id           String   @id @default(cuid())
  moduloId     String
  ordem        Int // posição dentro do módulo
  descricao    String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  modulo ModuloCurso @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  @@unique([moduloId, ordem])
  @@index([moduloId])
  @@map("ementa_itens")
}

model Turma {
  id             String      @id @default(cuid())
  unidadeId      String
  cursoId        String
  codigo         String      @unique // ex.: "BB-2026-1"
  profissionalId String // instrutor responsável
  diasHorario    String // ex.: "Seg/Qua 14h-17h"
  sala           String?
  inicioEm       DateTime
  fimEm          DateTime?
  vagasTotais    Int
  status         StatusTurma @default(INSCRICOES_ABERTAS)
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  unidade    Unidade      @relation(fields: [unidadeId], references: [id])
  curso      Curso        @relation(fields: [cursoId], references: [id])
  instrutor  Profissional @relation(fields: [profissionalId], references: [id])
  matriculas Matricula[]
  aulas      Aula[]

  @@index([unidadeId, status])
  @@map("turmas")
}

model Matricula {
  id                     String          @id @default(cuid())
  unidadeId              String
  turmaId                String
  fichaId                String
  membroId               String? // dependente matriculado
  status                 StatusMatricula @default(ATIVA)
  posicaoEspera          Int? // posição na lista de espera
  // LGPD: matrícula de menor de 18 exige consentimento do responsável (titular).
  // Preenchido com o instante do consentimento; null para maiores de idade.
  consentidoPorTitularEm DateTime?
  criadoPor              String? // userId de quem matriculou
  criadoEm               DateTime        @default(now())
  atualizadoEm           DateTime        @updatedAt

  unidade     Unidade         @relation(fields: [unidadeId], references: [id])
  turma       Turma           @relation(fields: [turmaId], references: [id])
  ficha       FichaCidada     @relation(fields: [fichaId], references: [id])
  membro      MembroFamiliar? @relation(fields: [membroId], references: [id])
  presencas   Presenca[]
  certificado Certificado?

  @@unique([turmaId, fichaId, membroId])
  @@index([unidadeId, status])
  @@map("matriculas")
}

model Aula {
  id             String    @id @default(cuid())
  unidadeId      String
  turmaId        String
  data           DateTime
  conteudo       String?
  profissionalId String // instrutor que ministrou
  encerradaEm    DateTime? // chamada encerrada ("selo")
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  unidade   Unidade      @relation(fields: [unidadeId], references: [id])
  turma     Turma        @relation(fields: [turmaId], references: [id])
  instrutor Profissional @relation(fields: [profissionalId], references: [id])
  presencas Presenca[]

  @@index([turmaId, data])
  @@map("aulas")
}

model Presenca {
  id           String         @id @default(cuid())
  aulaId       String
  matriculaId  String
  status       StatusPresenca
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  aula      Aula      @relation(fields: [aulaId], references: [id])
  matricula Matricula @relation(fields: [matriculaId], references: [id])

  @@unique([aulaId, matriculaId])
  @@map("presencas")
}

model Certificado {
  id                   String   @id @default(cuid())
  unidadeId            String
  matriculaId          String   @unique
  codigoVerificacao    String   @unique @default(cuid()) // validação pública
  cargaHorariaCumprida Int
  presencaPct          Decimal  @db.Decimal(5, 2)
  emitidoEm            DateTime @default(now())
  emitidoPor           String? // userId de quem emitiu

  unidade   Unidade   @relation(fields: [unidadeId], references: [id])
  matricula Matricula @relation(fields: [matriculaId], references: [id])

  @@map("certificados")
}

// ============================================================
// Educacional / Creche (Fase 3) — blueprint docs/BLUEPRINT-EDUCACIONAL-FASE3.md
// Criança = MembroFamiliar (sem modelo novo); responsável = titular da FichaCidada;
// alergias usam o modelo Alergia existente (Alergia.membroId).
// ============================================================

enum StatusDiario {
  ABERTO
  FECHADO
}

enum TipoRegistroRotina {
  ALIMENTACAO
  SONO
  HIGIENE
  ATIVIDADE
  OCORRENCIA
}

enum SentidoCheck {
  ENTRADA
  SAIDA
}

// Resposta da família: confirmação de presença em evento (RSVP) e o
// "vem amanhã?" da creche. SIM/NAO explícitos — sem default (a ausência
// de registro = "não respondeu", estado distinto de "não vem").
enum RespostaPresenca {
  SIM
  NAO
}

// Status do evento no calendário da unidade. CANCELADO é "soft" (mantém
// a trilha; nunca apagamos o que a família já confirmou).
enum StatusEvento {
  AGENDADO
  CANCELADO
}

// Autorização de imagem granular, POR CRIANÇA e POR FINALIDADE, revogável,
// default NEGADO (LGPD Art. 14). Transversal: será reutilizada pelo Esportivo
// e pelo Banco de Modelos da Capacitação (Fase 2).
enum EscopoImagem {
  USO_INTERNO // identificação interna (ficha, chamada)
  REDES_IFP // divulgação nas redes do instituto
  IMPRENSA // cessão para imprensa/parceiros
}

model AutorizacaoImagem {
  id           String         @id @default(cuid())
  fichaId      String
  ficha        FichaCidada    @relation(fields: [fichaId], references: [id])
  membroId     String // o menor — autorização é POR CRIANÇA
  membro       MembroFamiliar @relation(fields: [membroId], references: [id])
  escopo       EscopoImagem
  concedido    Boolean        @default(false) // default: NÃO
  versaoTermo  String
  registradoEm DateTime       @default(now())
  revogadoEm   DateTime? // revogação = efeito imediato; nunca deletar (trilha)
  revogadoPor  String? // userId
  criadoPor    String?

  @@unique([membroId, escopo, versaoTermo])
  @@index([membroId])
  @@map("autorizacoes_imagem")
}

model TurmaInfantil {
  id             String              @id @default(cuid())
  unidadeId      String
  unidade        Unidade             @relation(fields: [unidadeId], references: [id])
  nome           String // "Jardim A"
  faixaEtariaMin Int // em meses
  faixaEtariaMax Int
  capacidade     Int
  profissionalId String // educador(a) referência
  educador       Profissional        @relation(fields: [profissionalId], references: [id])
  ativa          Boolean             @default(true)
  criadoEm       DateTime            @default(now())
  atualizadoEm   DateTime            @updatedAt
  matriculas     MatriculaInfantil[]
  comunicados    Comunicado[]
  eventos        EventoUnidade[]

  @@index([unidadeId])
  @@map("turmas_infantis")
}

model MatriculaInfantil {
  id                  String         @id @default(cuid())
  unidadeId           String
  unidade             Unidade        @relation(fields: [unidadeId], references: [id])
  turmaId             String
  turma               TurmaInfantil  @relation(fields: [turmaId], references: [id])
  fichaId             String
  ficha               FichaCidada    @relation(fields: [fichaId], references: [id])
  membroId            String // a criança — SEMPRE um MembroFamiliar (não-opcional aqui)
  crianca             MembroFamiliar @relation(fields: [membroId], references: [id])
  consentimentoLgpdEm DateTime // Art. 14: consentimento específico e destacado do responsável legal
  ativa               Boolean        @default(true)
  criadoPor           String?
  criadoEm            DateTime       @default(now())
  atualizadoEm        DateTime       @updatedAt

  @@unique([turmaId, membroId])
  @@index([unidadeId])
  @@map("matriculas_infantis")
}

model ResponsavelAutorizado {
  id                String         @id @default(cuid())
  fichaId           String
  ficha             FichaCidada    @relation(fields: [fichaId], references: [id])
  membroId          String // autorização é POR CRIANÇA, não por família
  crianca           MembroFamiliar @relation(fields: [membroId], references: [id])
  nome              String
  documento         String // doc conferido no ato
  parentesco        String // "avó", "tio", "van escolar"
  fotoUrl           String? // identificação visual no check-out
  restricaoJudicial Boolean        @default(false) // destaque vermelho: NUNCA liberar
  vigenteAte        DateTime?
  revogadoEm        DateTime? // revogação = efeito imediato; nunca deletar (trilha)
  revogadoPor       String? // userId
  criadoPor         String?
  criadoEm          DateTime       @default(now())
  atualizadoEm      DateTime       @updatedAt
  checks            CheckInOut[]

  @@index([membroId])
  @@map("responsaveis_autorizados")
}

model CheckInOut {
  id             String                @id @default(cuid())
  unidadeId      String
  unidade        Unidade               @relation(fields: [unidadeId], references: [id])
  membroId       String
  crianca        MembroFamiliar        @relation(fields: [membroId], references: [id])
  sentido        SentidoCheck
  ocorridoEm     DateTime              @default(now())
  autorizadoId   String // quem entregou (ENTRADA) ou retirou (SAIDA)
  autorizado     ResponsavelAutorizado @relation(fields: [autorizadoId], references: [id])
  profissionalId String // educador que registrou — FK forte (segurança física = autoria de prontuário)
  registradoPor  Profissional          @relation(fields: [profissionalId], references: [id])

  @@index([unidadeId, ocorridoEm])
  @@index([membroId, ocorridoEm])
  @@map("checkins_saidas")
}

model DiarioDia {
  id             String           @id @default(cuid())
  unidadeId      String
  unidade        Unidade          @relation(fields: [unidadeId], references: [id])
  membroId       String
  crianca        MembroFamiliar   @relation(fields: [membroId], references: [id])
  data           DateTime         @db.Date
  status         StatusDiario     @default(ABERTO)
  fechadoEm      DateTime? // selo: só visível à família após fechar (padrão Atendimento.encerradoEm)
  profissionalId String? // educador que fechou
  fechadoPor     Profissional?    @relation(fields: [profissionalId], references: [id])
  criadoEm       DateTime         @default(now())
  atualizadoEm   DateTime         @updatedAt
  registros      RegistroRotina[]

  @@unique([membroId, data])
  @@map("diarios_dia")
}

model RegistroRotina {
  id             String             @id @default(cuid())
  diarioId       String
  diario         DiarioDia          @relation(fields: [diarioId], references: [id])
  tipo           TipoRegistroRotina
  descricao      String // "Almoço: aceitou bem" (alimentada por tags de 1 toque — meta 5–10s)
  ocorridoEm     DateTime           @default(now())
  profissionalId String
  registradoPor  Profissional       @relation(fields: [profissionalId], references: [id])

  @@index([diarioId])
  @@map("registros_rotina")
}

model Comunicado {
  id         String              @id @default(cuid())
  unidadeId  String
  unidade    Unidade             @relation(fields: [unidadeId], references: [id])
  turmaId    String? // null = geral da unidade
  turma      TurmaInfantil?      @relation(fields: [turmaId], references: [id])
  titulo     String
  corpo      String
  critico    Boolean             @default(false) // crítico exige confirmação de leitura
  enviadoPor String? // userId administrativo
  criadoEm   DateTime            @default(now())
  leituras   ComunicadoLeitura[]

  @@index([unidadeId])
  @@map("comunicados")
}

model ComunicadoLeitura {
  id           String      @id @default(cuid())
  comunicadoId String
  comunicado   Comunicado  @relation(fields: [comunicadoId], references: [id])
  fichaId      String
  ficha        FichaCidada @relation(fields: [fichaId], references: [id])
  lidoEm       DateTime    @default(now())

  @@unique([comunicadoId, fichaId])
  @@map("comunicados_leituras")
}

// ============================================================
// Família — agenda de eventos + confirmação de presença (U6)
// Calendário da unidade que a família vê no portal, RSVP por criança e o
// "vem amanhã?" da creche. Tudo escopado por unidade/turma; o portal resolve
// ownership por User.fichaCidadaId (nunca aceita fichaId/membroId de outra
// família). Models aditivos, sem alterar o que já existe.
// ============================================================

model EventoUnidade {
  id            String         @id @default(cuid())
  unidadeId     String
  unidade       Unidade        @relation(fields: [unidadeId], references: [id])
  turmaId       String? // null = evento geral da unidade; senão restrito à turma
  turma         TurmaInfantil? @relation(fields: [turmaId], references: [id])
  titulo        String
  descricao     String?
  local         String?
  inicioEm      DateTime
  fimEm         DateTime?
  // Eventos como passeio/festa pedem RSVP; reunião informativa pode não pedir.
  pedeConfirmacao Boolean      @default(false)
  status        StatusEvento   @default(AGENDADO)
  criadoPor     String? // userId administrativo
  criadoEm      DateTime       @default(now())
  atualizadoEm  DateTime       @updatedAt
  confirmacoes  ConfirmacaoEvento[]

  @@index([unidadeId, inicioEm])
  @@map("eventos_unidade")
}

model ConfirmacaoEvento {
  id            String           @id @default(cuid())
  eventoId      String
  evento        EventoUnidade    @relation(fields: [eventoId], references: [id])
  fichaId       String // a família que respondeu (ownership)
  ficha         FichaCidada      @relation(fields: [fichaId], references: [id])
  membroId      String // a criança da família
  membro        MembroFamiliar   @relation(fields: [membroId], references: [id])
  resposta      RespostaPresenca
  observacao    String? // ex.: "chega 30min atrasada"
  respondidoEm  DateTime         @default(now())
  atualizadoEm  DateTime         @updatedAt

  // Uma resposta por criança por evento (re-confirmar = update).
  @@unique([eventoId, membroId])
  @@index([fichaId])
  @@map("confirmacoes_evento")
}

model PresencaCreche {
  id           String           @id @default(cuid())
  fichaId      String // a família que respondeu (ownership)
  ficha        FichaCidada      @relation(fields: [fichaId], references: [id])
  membroId     String // a criança
  membro       MembroFamiliar   @relation(fields: [membroId], references: [id])
  data         DateTime         @db.Date // dia civil (São Paulo) — molde DiarioDia
  resposta     RespostaPresenca
  observacao   String?
  respondidaEm DateTime         @default(now())
  atualizadaEm DateTime         @updatedAt

  // Uma confirmação por criança por dia (re-responder = update).
  @@unique([membroId, data])
  @@index([fichaId, data])
  @@map("presencas_creche")
}

// ============================================================
// NOTAS PARA PRÓXIMAS MIGRATIONS
// ============================================================
// - Centro Médico fase 2: Prescrição estruturada, Atestado, ExameAnexado,
//   adendos pós-selo (imutabilidade médico-legal), fluxo de enfermagem.
// - Capacitação fase 2: AulaPlano (planejamento de aulas), lista de espera
//   automática, PDF do certificado.
// - Esportivo: Modalidade, Turma, Aluno, Graduacao, AtestadoMedico (reusa
//   AutorizacaoImagem do Educacional).
// - Educacional fase 2: FichaSaudeCrianca (laudos/medicação), mensagem 1:1
//   família↔instituto, fotos no diário (watermark), esporte/graduações.
// - Comum: Notificacao, MensagemWhatsApp, MensagemEmail.
// - RLS: configurar policies no Postgres por unidadeId após migration inicial.

// ============================================================
// Esportivo (Fase 3) — molde: trio da Capacitação
// Modalidade ≈ Curso · TurmaEsportiva ≈ Turma · Graduacao ≈ Certificado.
// Reusa StatusTurma/StatusMatricula. Treinos + chamada (molde Aula/Presenca)
// ficam para o próximo incremento.
// ============================================================

model Modalidade {
  id               String   @id @default(cuid())
  unidadeId        String
  nome             String // Judô, Futsal, Ballet...
  /// Trilha ORDENADA de graduações da modalidade (ex.: faixas do judô).
  trilhaGraduacoes String[]
  ativo            Boolean  @default(true)
  criadoEm         DateTime @default(now())
  atualizadoEm     DateTime @updatedAt

  unidade Unidade          @relation(fields: [unidadeId], references: [id])
  turmas  TurmaEsportiva[]

  @@unique([unidadeId, nome])
  @@map("modalidades")
}

model TurmaEsportiva {
  id             String      @id @default(cuid())
  unidadeId      String
  modalidadeId   String
  codigo         String      @unique // ex.: "JUDO-2026-1"
  profissionalId String // instrutor responsável
  diasHorario    String // ex.: "Ter/Qui 9h-10h30"
  local          String?
  faixaEtariaMin Int? // em anos (categoria por idade)
  faixaEtariaMax Int?
  inicioEm       DateTime
  fimEm          DateTime?
  vagasTotais    Int
  status         StatusTurma @default(EM_ANDAMENTO)
  criadoEm       DateTime    @default(now())
  atualizadoEm   DateTime    @updatedAt

  unidade    Unidade              @relation(fields: [unidadeId], references: [id])
  modalidade Modalidade           @relation(fields: [modalidadeId], references: [id])
  instrutor  Profissional         @relation(fields: [profissionalId], references: [id])
  matriculas MatriculaEsportiva[]
  treinos    TreinoEsportivo[]

  @@index([unidadeId, status])
  @@map("turmas_esportivas")
}

model MatriculaEsportiva {
  id            String          @id @default(cuid())
  unidadeId     String
  turmaId       String
  fichaId       String
  membroId      String? // dependente matriculado; ausente = titular
  status        StatusMatricula @default(ATIVA)
  posicaoEspera Int?
  criadoPor     String? // userId de quem matriculou
  criadoEm      DateTime        @default(now())
  atualizadoEm  DateTime        @updatedAt

  unidade         Unidade          @relation(fields: [unidadeId], references: [id])
  turma           TurmaEsportiva   @relation(fields: [turmaId], references: [id])
  ficha           FichaCidada      @relation(fields: [fichaId], references: [id])
  membro          MembroFamiliar?  @relation(fields: [membroId], references: [id])
  graduacoes      Graduacao[]
  presencasTreino PresencaTreino[]

  @@unique([turmaId, fichaId, membroId])
  @@index([unidadeId, status])
  @@map("matriculas_esportivas")
}

model Graduacao {
  id                String   @id @default(cuid())
  unidadeId         String
  matriculaId       String
  nivel             String // precisa pertencer à trilha da modalidade
  codigoVerificacao String   @unique @default(cuid()) // validação pública (molde certificado)
  observacao        String?
  concedidaEm       DateTime @default(now())
  concedidaPor      String? // userId de quem concedeu

  unidade   Unidade            @relation(fields: [unidadeId], references: [id])
  matricula MatriculaEsportiva @relation(fields: [matriculaId], references: [id])

  @@unique([matriculaId, nivel]) // mesmo nível não é concedido duas vezes
  @@map("graduacoes")
}

model TreinoEsportivo {
  id             String    @id @default(cuid())
  unidadeId      String
  turmaId        String
  data           DateTime
  conteudo       String?
  profissionalId String // instrutor que conduziu
  encerradoEm    DateTime? // chamada encerrada ("selo" — imutável depois)
  criadoEm       DateTime  @default(now())
  atualizadoEm   DateTime  @updatedAt

  unidade   Unidade          @relation(fields: [unidadeId], references: [id])
  turma     TurmaEsportiva   @relation(fields: [turmaId], references: [id])
  instrutor Profissional     @relation(fields: [profissionalId], references: [id])
  presencas PresencaTreino[]

  @@index([turmaId, data])
  @@map("treinos_esportivos")
}

model PresencaTreino {
  id           String         @id @default(cuid())
  treinoId     String
  matriculaId  String
  status       StatusPresenca
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  treino    TreinoEsportivo    @relation(fields: [treinoId], references: [id])
  matricula MatriculaEsportiva @relation(fields: [matriculaId], references: [id])

  @@unique([treinoId, matriculaId])
  @@map("presencas_treino")
}

// ============================================================
// Mensagem 1:1 família ↔ instituto (killer feature — ClassApp)
// Protege o número pessoal da equipe; 1 conversa por criança.
// ============================================================

model ConversaFamilia {
  id           String   @id @default(cuid())
  unidadeId    String
  membroId     String   @unique // 1 thread por criança
  fichaId      String // família dona (ownership do portal)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  unidade   Unidade           @relation(fields: [unidadeId], references: [id])
  crianca   MembroFamiliar    @relation(fields: [membroId], references: [id])
  ficha     FichaCidada       @relation(fields: [fichaId], references: [id])
  mensagens MensagemFamilia[]

  @@index([unidadeId])
  @@map("conversas_familia")
}

model MensagemFamilia {
  id         String    @id @default(cuid())
  conversaId String
  autorId    String // userId de quem escreveu
  /// true = equipe do instituto; false = responsável familiar.
  ladoEquipe Boolean
  corpo      String
  /// Quando o lado OPOSTO leu (recibo de leitura por mensagem).
  lidaEm     DateTime?
  criadoEm   DateTime  @default(now())

  conversa ConversaFamilia @relation(fields: [conversaId], references: [id])
  autor    User            @relation(fields: [autorId], references: [id])

  @@index([conversaId, criadoEm])
  @@map("mensagens_familia")
}
